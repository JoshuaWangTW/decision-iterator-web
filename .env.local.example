# Copy this file to .env.local and fill in values

# Anthropic API key (required for LLM=real)
ANTHROPIC_API_KEY=

# LLM mode:
#   mock   — 不需金鑰,固定回覆,驗流程用
#   real   — Anthropic API（按 token 計費;預設,可部署到 Vercel）
#   codex  — 本機 codex CLI,吃 ChatGPT 訂閱 token（免 API 計費；僅單機,需已登入 codex）
LLM=mock

# Storage backend: fs (local .data/sessions/) | supabase | pg
STORAGE=fs

# Supabase (only needed when STORAGE=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL (only needed when STORAGE=pg)
# On Zeabur: set DATABASE_URL=${POSTGRES_CONNECTION_STRING}
DATABASE_URL=

# LLM model override for LLM=real (default: claude-sonnet-4-6)
MODEL=

# codex 模型（僅 LLM=codex）。留空 → 用 codex 自身 config 的模型（最強預設,如 gpt-5.6-sol）。
# 要往下降就填,例如 CODEX_MODEL=gpt-5.1
CODEX_MODEL=

# LINE Bot (only needed for /api/line/webhook)
# Get from LINE Developers console → Messaging API channel
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Public base URL for LINE reply links (e.g. https://<domain>.zeabur.app)
# Do NOT use NEXT_PUBLIC_ prefix — server-only
PUBLIC_BASE_URL=
