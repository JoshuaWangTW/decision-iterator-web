# Copy this file to .env.local and fill in values

# Anthropic API key (required for LLM=real)
ANTHROPIC_API_KEY=

# LLM mode: mock (no API key needed, deterministic E2E) | real (default)
LLM=mock

# Storage backend: fs (local .data/sessions/) | supabase
STORAGE=fs

# Supabase (only needed when STORAGE=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
